{
  "name": "ccctw-music",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "prepare": "husky",
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "format": "prettier .github apps packages docs e2e scripts components edge-functions functions store styles util *.json *.ts *.md --write",
    "format:check": "prettier .github apps packages docs e2e scripts components edge-functions functions store styles util *.json *.ts *.md --check",
    "test": "pnpm test:unit",
    "test:unit": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:live-playback": "tsx scripts/verify-live-playback.ts",
    "score:ui": "playwright test e2e/ui-style-gate.spec.ts",
    "check:targets": "turbo check",
    "quality": "pnpm format:check && pnpm build && pnpm test:unit && pnpm test:e2e && pnpm score:ui && pnpm check:targets",
    "ci": "pnpm quality",
    "cloudflare:provision": "tsx scripts/provision-cloudflare.ts",
    "github:secrets": "tsx scripts/sync-github-secrets.ts",
    "dev:web": "pnpm --filter @ccctw-music/web dev",
    "dev:server": "pnpm --filter @ccctw-music/server dev",
    "deploy:server": "pnpm --filter @ccctw-music/server run deploy",
    "deploy:server:edgeone": "pnpm --filter @ccctw-music/server run deploy:edgeone",
    "edgeone:provision": "tsx scripts/provision-edgeone.ts"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,css,yml,yaml}": "prettier --write"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "@testing-library/react": "latest",
    "@testing-library/user-event": "latest",
    "@types/node": "latest",
    "@vitejs/plugin-react": "latest",
    "@vitest/coverage-v8": "latest",
    "husky": "latest",
    "jsdom": "latest",
    "lint-staged": "latest",
    "prettier": "latest",
    "vite-tsconfig-paths": "latest",
    "turbo": "latest",
    "typescript": "latest",
    "tsx": "latest",
    "vitest": "latest"
  }
}
