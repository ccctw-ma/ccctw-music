{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CCCTW Music",
  "version": "0.1.0",
  "identifier": "com.ccctw.music",
  "build": {
    "beforeDevCommand": "pnpm --filter @ccctw-music/web dev",
    "beforeBuildCommand": "pnpm --filter @ccctw-music/web build",
    "frontendDist": "../../web/dist",
    "devUrl": "http://localhost:3000"
  },
  "app": {
    "windows": [
      {
        "title": "CCCTW Music",
        "width": 1200,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "msi", "deb", "appimage"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
  }
}
